{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "My IPTV",
  "version": "1.0.0",
  "identifier": "com.myiptv.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "My IPTV",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http: https: data: blob:; media-src 'self' http: https: data: blob:; connect-src 'self' http: https: tauri: asset:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../src/assets/my-iptv-logo.png"
    ]
  }
}
